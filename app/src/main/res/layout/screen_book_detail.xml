<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="45dp">

        <!-- Header Actions Bar (floating atop banner) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="#20000000">

            <TextView
                android:id="@+id/btn_detail_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="←"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1.0" />

            <TextView
                android:id="@+id/btn_detail_share"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="📤"
                android:textSize="18sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_detail_more"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="⋮"
                android:textSize="18sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Library Wide Banner Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="240dp">
            
            <ImageView
                android:id="@+id/img_detail_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Solid visual fade to bottom background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#70000000"/>

            <!-- Floating Book Cover -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="150dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp">
                
                <ImageView
                    android:id="@+id/img_detail_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Workspace premium gold sticker -->
                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|right"
                    android:layout_margin="4dp"
                    android:background="#FED65B"
                    android:gravity="center"
                    android:text="⭐"
                    android:textSize="10sp" />
            </FrameLayout>

        </FrameLayout>

        <!-- Book metadata section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/txt_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Echoes of Eternity"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:gravity="center" />

            <TextView
                android:id="@+id/txt_detail_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="bởi Eleanor Vance"
                android:textSize="13sp"
                android:textColor="@color/colorOnBackgroundSepia"
                android:layout_marginTop="2dp" />

            <!-- Stats bar -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Đã hoàn thành"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/colorOutlineVariant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁️ 1.2M Lượt xem"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/colorOutlineVariant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.8"
                    android:textSize="11sp"
                    android:textColor="@color/colorSecondary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Start reading CTAs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btn_detail_start_read"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:background="@drawable/bg_pill_accent"
                    android:text="📖 Bắt đầu đọc"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btn_detail_bookmark"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_card_rounded"
                    android:text="＋"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:textColor="@color/colorOnBackground"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>

        <!-- Synopsis collapse layout container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tóm tắt nội dung"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/txt_detail_synopsis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trong một thế giới nơi ký ức có thể được lưu trữ và giao dịch như tiền tệ, Elara tìm thấy một mảnh ký ức không thuộc về bất kỳ ai. Nó chứa đựng bí mật về một nền văn minh đã mất, nơi công nghệ và ma thuật hòa quyện. Khi cô bắt đầu giải mã những thông điệp ẩn giấu, Elara bị cuốn vào một âm mưu nguy hiểm liên quan đến những gia tộc quyền lực nhất..."
                android:textSize="13sp"
                android:textColor="@color/colorOnBackgroundSepia"
                android:maxLines="3"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/btn_toggle_synopsis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem thêm"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Dynamic Chapter List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Danh sách chương"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1.0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="124 Chương"
                    android:textSize="11sp"
                    android:textColor="@color/colorOutline" />
            </LinearLayout>

            <!-- Card content of chapters -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="@color/colorSurfaceContainer">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:text="CHƯƠNG MỚI NHẤT"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnBackgroundSepia" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⇅"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <!-- Chapter 1 Row -->
                <LinearLayout
                    android:id="@+id/btn_chapter_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chương 1: Mảnh ký ức lạc loài"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnBackground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12/10/2023"
                        android:textSize="10sp"
                        android:textColor="@color/colorOutline"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1071787C" />

                <!-- Chapter 2 Row -->
                <LinearLayout
                    android:id="@+id/btn_chapter_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chương 2: Chợ đen Elysium"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnBackground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15/10/2023"
                        android:textSize="10sp"
                        android:textColor="@color/colorOutline"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1071787C" />

                <!-- Chapter 3 Row (Locked) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chương 3: Sự truy đuổi trong bóng tối"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOutline" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="18/10/2023"
                            android:textSize="10sp"
                            android:textColor="@color/colorOutline"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1071787C" />

                <!-- Chapter 4 Row (Locked) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chương 4: Gặp gỡ The Archivist"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOutline" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="22/10/2023"
                            android:textSize="10sp"
                            android:textColor="@color/colorOutline"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- See all chapters footer -->
                <TextView
                    android:id="@+id/btn_view_all_chapters"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:background="@color/colorSurfaceContainer"
                    android:text="Xem tất cả chương"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>

        <!-- Reviews / Comments section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bình luận cộng đồng"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1.0" />

                <TextView
                    android:id="@+id/btn_write_comment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Viết bình luận 📝"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Active Reviews Stack -->
            <LinearLayout
                android:id="@+id/panel_reviews_stack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Review 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_chip"
                            android:text="M"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Minh Tuấn"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorOnBackground" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2 ngày trước"
                                android:textSize="9sp"
                                android:textColor="@color/colorOutline" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐⭐⭐⭐⭐"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cốt truyện thực sự sáng tạo! Cách tác giả xây dựng thế giới nơi ký ức là tiền tệ rất độc đáo và cuốn hút ngay từ những chương đầu."
                        android:textSize="12sp"
                        android:textColor="@color/colorOnBackgroundSepia"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Review 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <ImageView
                            android:id="@+id/img_commenter_avatar"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_chip"
                            android:layout_marginEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lan Chi"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/colorOnBackground" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 ngày trước"
                                android:textSize="9sp"
                                android:textColor="@color/colorOutline" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐⭐⭐⭐☆"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mong chờ diễn biến tiếp theo. Tuyệt vời!"
                        android:textSize="12sp"
                        android:textColor="@color/colorOnBackgroundSepia"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- More comments button -->
            <TextView
                android:id="@+id/btn_see_all_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Xem thêm 45 bình luận"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
