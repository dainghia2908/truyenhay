<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tổng quan hệ thống"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thống kê nhanh và hoạt động gần đây."
            android:textSize="13sp"
            android:textColor="@color/colorOnBackgroundSepia"
            android:layout_marginBottom="16dp" />

        <!-- Metrics Bento row cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- Card 1: Books -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📖 Total Books"
                        android:textSize="11sp"
                        android:textColor="@color/colorOutline" />
                    <View android:layout_width="0dp" android:layout_weight="1.0" android:layout_height="1dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+12%"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnSecondaryContainer"
                        android:background="@drawable/bg_active_nav"
                        android:paddingHorizontal="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,248"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Card 2: Chapters -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📜 Total Chapters"
                        android:textSize="11sp"
                        android:textColor="@color/colorOutline" />
                    <View android:layout_width="0dp" android:layout_weight="1.0" android:layout_height="1dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+5%"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnSecondaryContainer"
                        android:background="@drawable/bg_active_nav"
                        android:paddingHorizontal="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="34,502"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Card 3: Views -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👁️ Total Views"
                        android:textSize="11sp"
                        android:textColor="@color/colorOutline" />
                    <View android:layout_width="0dp" android:layout_weight="1.0" android:layout_height="1dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+28%"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnSecondaryContainer"
                        android:background="@drawable/bg_active_nav"
                        android:paddingHorizontal="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.5M"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Manage Books Headers -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quản lý truyện"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="12dp" />

        <!-- Styled Static book list acting as manage panel representation -->
        <LinearLayout
            android:id="@+id/panel_manage_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:layout_marginBottom="24dp">

            <!-- Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">
                
                <ImageView
                    android:id="@+id/img_admin_book_1"
                    android:layout_width="32dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:background="#20000000" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Biên Niên Sử Vùng Đất Khí"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnBackground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Huyền Vĩ • 156 ch."
                        android:textSize="10sp"
                        android:textColor="@color/colorOutline" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="14sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/btn_admin_delete_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️"
                    android:textColor="@color/textRed"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1571787C" />

            <!-- Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">
                
                <ImageView
                    android:id="@+id/img_admin_book_2"
                    android:layout_width="32dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:background="#20000000" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bóng Đêm Thức Tỉnh"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnBackground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dạ Hành • 89 ch."
                        android:textSize="10sp"
                        android:textColor="@color/colorOutline" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️"
                    android:textSize="14sp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/btn_admin_delete_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️"
                    android:textColor="@color/textRed"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ADD New Story Form Card layout elements -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm / Sửa Truyện"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="16dp" />

            <!-- Title inputs -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên truyện"
                android:textSize="11sp"
                android:textColor="@color/colorOutline"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_admin_title"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip"
                android:hint="Nhập tên truyện..."
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <!-- Author input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tác giả"
                android:textSize="11sp"
                android:textColor="@color/colorOutline"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_admin_author"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip"
                android:hint="Tên tác giả..."
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <!-- Genres Category tags input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thể loại (Tags)"
                android:textSize="11sp"
                android:textColor="@color/colorOutline"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_admin_tags"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip"
                android:hint="Ví dụ: Tiên hiệp, Xuyên không..."
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- Styled Dashed drag upload cover zone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ảnh bìa"
                android:textSize="11sp"
                android:textColor="@color/colorOutline"
                android:layout_marginBottom="4dp" />

            <!-- Dashed outline via standard layout spacer with secondary colors -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📤"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click bừa để nhập URL ảnh demo"
                    android:textColor="@color/colorOnBackgroundSepia"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Buttons cancel & save -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_admin_cancel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:background="@drawable/bg_chip"
                    android:text="Hủy"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnBackground"
                    android:gravity="center"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btn_admin_save"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:background="@drawable/bg_pill_accent"
                    android:text="Lưu lại"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
