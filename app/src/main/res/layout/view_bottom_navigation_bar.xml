<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_navigation_bar"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@color/colorBackground"
    android:gravity="center_vertical"
    android:elevation="8dp">

    <!-- Home Tab -->
    <LinearLayout
        android:id="@+id/btn_nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.0"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        
        <LinearLayout
            android:id="@+id/layout_indicator_home"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/icon_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="16sp" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/txt_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/colorOutline"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Discover Tab -->
    <LinearLayout
        android:id="@+id/btn_nav_discover"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.0"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        
        <LinearLayout
            android:id="@+id/layout_indicator_discover"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/icon_discover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧭"
                android:textSize="16sp" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/txt_discover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover"
            android:textSize="10sp"
            android:textColor="@color/colorOutline"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Library Tab -->
    <LinearLayout
        android:id="@+id/btn_nav_library"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.0"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        
        <LinearLayout
            android:id="@+id/layout_indicator_library"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/icon_library"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚"
                android:textSize="16sp" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/txt_library"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Library"
            android:textSize="10sp"
            android:textColor="@color/colorOutline"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Profile Tab -->
    <LinearLayout
        android:id="@+id/btn_nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.0"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">
        
        <LinearLayout
            android:id="@+id/layout_indicator_profile"
            android:layout_width="60dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/icon_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="16sp" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/txt_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="10sp"
            android:textColor="@color/colorOutline"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
