<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Custom Styled Capsule Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_rounded"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.0"
                android:hint="Search stories, authors, or genres..."
                android:background="@null"
                android:textSize="13sp"
                android:textColor="@color/colorOnBackground"
                android:paddingLeft="8dp"
                android:maxLines="1"
                android:inputType="text" />

            <!-- Tune filter circle button -->
            <TextView
                android:id="@+id/btn_filter_search"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_active_nav"
                android:text="⚙"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Trending Now -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trending Now"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="12dp" />

        <!-- Filter Rows 1 and 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tag_trending_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 The Obsidian Crown"
                android:textSize="12sp"
                android:textColor="@color/colorOnBackground"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tag_trending_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 Cyberpunk Dreams"
                android:textSize="12sp"
                android:textColor="@color/colorOnBackground"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tag_trending_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vampire Academy"
                android:textSize="12sp"
                android:textColor="@color/colorOnBackground"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tag_trending_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LitRPG"
                android:textSize="12sp"
                android:textColor="@color/colorOnBackground"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Browse by Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse by Category"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="12dp" />

        <!-- Category Bento Bento Cards Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Giant Epic Fantasy Card -->
            <FrameLayout
                android:id="@+id/btn_category_fantasy"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:id="@+id/img_cat_fantasy"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Transparent filter overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#7F000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏰"
                        android:textSize="18sp"
                        android:textColor="@color/colorSecondaryContainer" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Epic Fantasy"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Row 1: Mystery & Romance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Mystery Card -->
                <FrameLayout
                    android:id="@+id/btn_category_mystery"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:id="@+id/img_cat_mystery"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7F000000"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡️"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mystery"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Romance Card -->
                <FrameLayout
                    android:id="@+id/btn_category_romance"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:layout_marginLeft="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:id="@+id/img_cat_romance"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7F000000"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❤️"
                            android:textSize="16sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Romance"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>

            <!-- Row 2: Sci-Fi & All Genres -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:orientation="horizontal">

                <!-- Sci-Fi Card -->
                <FrameLayout
                    android:id="@+id/btn_category_scifi"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <ImageView
                        android:id="@+id/img_cat_scifi"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#7F000000"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="bottom"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚀"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sci-Fi"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </FrameLayout>

                <!-- All Genres Selector Card -->
                <LinearLayout
                    android:id="@+id/btn_category_all"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.0"
                    android:layout_marginLeft="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_rounded"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎛️"
                        android:textSize="24sp"
                        android:textColor="@color/colorOnBackground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Genres"
                        android:textSize="12sp"
                        android:textColor="@color/colorOnBackground"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
